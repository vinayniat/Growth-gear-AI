PORT=5000
NODE_ENV=development

# --- Database ---
# Use a PostgreSQL connection string for production (e.g., Neon, Supabase, Render Postgres)
DATABASE_URL=sqlite://database.sqlite

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here

# --- JWT Auth ---
JWT_SECRET=your_jwt_secret_here_change_in_production

# --- Admin ---
ADMIN_PIN=1526

# --- AI Settings ---
AI_TIMEOUT_MS=30000

# --- Firebase Authentication ---
# OPTION 1 (Recommended for production): Paste the full JSON content of your
# Firebase service account key. Download it from:
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Then set it as a single-line JSON string:
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
FIREBASE_SERVICE_ACCOUNT_KEY=

# OPTION 2 (Fallback): If FIREBASE_SERVICE_ACCOUNT_KEY is not set, the app will use
# the Google Identity Toolkit HTTP API to verify tokens. In this case, you MUST
# provide the Firebase Web API Key (found in Firebase Console > Project Settings > General).
FIREBASE_API_KEY=your_firebase_web_api_key_here
